@using frontend.Models
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (FullViewport)
{
    <canvas @ref="_canvasRef" class="cad-canvas-full"></canvas>
}
else
{
    <div class="cad-preview-2d">
        <canvas @ref="_canvasRef" width="1100" height="750"></canvas>

        <div class="cad-stats">
            <h4>Track Statistics</h4>
            <div class="stat-row">
                <span class="stat-label">Total Straight Track:</span>
                <span class="stat-value">@($"{Result?.TotalTrackLength:F0} mm")</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Total Curve Length:</span>
                <span class="stat-value">@($"{Result?.TotalCurveLength:F0} mm")</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Number of Curves:</span>
                <span class="stat-value">@Result?.CurveCount</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Total Entities:</span>
                <span class="stat-value">@Result?.Entities.Count</span>
            </div>
            @if (Result?.EntityTypeCounts?.Any() == true)
            {
                <div class="stat-row">
                    <span class="stat-label">By type:</span>
                    <span class="stat-value">@string.Join(", ", Result.EntityTypeCounts.Select(kv => $"{kv.Key}:{kv.Value}"))</span>
                </div>
            }
        </div>

        <div class="cad-legend">
            <div class="legend-item"><span class="legend-color" style="background: #4499ff;"></span><span>Lines</span></div>
            <div class="legend-item"><span class="legend-color" style="background: #ff6644;"></span><span>Arcs / Circles</span></div>
            <div class="legend-item"><span class="legend-color" style="background: #b45309;"></span><span>Dimensions</span></div>
            <div class="legend-item"><span class="legend-color" style="background: #4b5563;"></span><span>Text labels</span></div>
        </div>

        @if (Dimensions.Any())
        {
            <div class="cad-dimensions">
                <h4>Detected Dimensions</h4>
                @foreach (var d in Dimensions)
                {
                    <div class="stat-row">
                        <span class="stat-label">@d.Layer</span>
                        <span class="stat-value">@d.Content</span>
                    </div>
                }
            </div>
        }

        @if (Notes.Any())
        {
            <div class="cad-notes">
                <h4>Drawing Notes &amp; Labels</h4>
                @foreach (var note in Notes)
                {
                    <div class="note-item">@note</div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public CadImportResult? Result { get; set; }

    [Parameter]
    public bool FullViewport { get; set; }

    private IEnumerable<TextItem> Dimensions =>
        Result?.Texts.Where(t => t.ItemType == "Dimension") ?? [];

    private IEnumerable<string> Notes =>
        Result?.Texts
            .Where(t => t.ItemType != "Dimension" && !string.IsNullOrWhiteSpace(t.Content) && t.Content.Length > 2)
            .Select(t => t.Content)
            .Distinct()
            .OrderBy(s => s)
        ?? Enumerable.Empty<string>();

    private ElementReference _canvasRef;
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Result != null)
        {
            await RenderCanvas();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Result != null)
        {
            await RenderCanvas();
        }
    }

    private async Task RenderCanvas()
    {
        if (_module == null)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cad-preview-2d.js");
        }

        if (Result != null)
        {
            if (FullViewport)
            {
                await _module.InvokeVoidAsync("resizeCadCanvas", _canvasRef);
            }
            await _module.InvokeVoidAsync("renderCadPreview", _canvasRef, Result);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module != null)
        {
            await _module.DisposeAsync();
        }
    }
}
